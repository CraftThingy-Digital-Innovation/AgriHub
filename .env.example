# ─── Server ────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
CLIENT_URL=https://agrihub.rumah-genbi.com

# ─── Database ──────────────────────────────────────────────────────────────
# Development (SQLite) — default, tidak perlu diubah
DATABASE_CLIENT=sqlite3
DATABASE_URL=./agrihub.sqlite

# Production (PostgreSQL) — uncomment & isi saat deploy
# DATABASE_CLIENT=pg
# DATABASE_URL=postgresql://user:password@host:5432/agrihub

# ─── Auth ──────────────────────────────────────────────────────────────────
JWT_SECRET=ganti_dengan_string_acak_yang_panjang_dan_aman

# ─── Puter.js AI (Sprint 2 - RAG & AI Chat) ────────────────────────────────
# Dapatkan API key di: https://puter.com/developers
PUTER_APP_ID=agrihub-indonesia

# ─── Midtrans Payment (Sprint 3 - Marketplace) ─────────────────────────────
# Dashboard: https://dashboard.midtrans.com → Settings → Access Keys
MIDTRANS_SERVER_KEY=
MIDTRANS_CLIENT_KEY=

# ─── Biteship Logistics (Sprint 4 - Shipping) ──────────────────────────────
# Dashboard: https://biteship.com/dashboard → API Keys
BITESHIP_API_KEY=

# ─── WhatsApp Bot (Sprint 3 - Baileys.js) ──────────────────────────────────
# Set 'true' untuk aktifkan WA bot, scan QR di terminal saat startup
ENABLE_WHATSAPP=false
# Opsional: Jika ingin menjalankan beberapa bot dalam 1 server secara paralel, set session name (misal: bot1, bot2)
WA_SESSION_NAME=main
