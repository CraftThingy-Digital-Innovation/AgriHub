# ── SERVER ──────────────────────────────────────
PORT=3001
NODE_ENV=development

# Database (SQLite untuk dev, ganti ke PostgreSQL/MySQL untuk prod)
DATABASE_CLIENT=sqlite3
DATABASE_URL=./dev.db
# DATABASE_CLIENT=pg
# DATABASE_URL=postgresql://user:password@localhost:5432/agrihub

# JWT
JWT_SECRET=ganti_dengan_secret_yang_kuat_min32chars

# Puter.js AI
PUTER_API_KEY=your_puter_api_key_here

# Midtrans Payment
MIDTRANS_SERVER_KEY=SB-Mid-server-xxxxxxxxxxxx
MIDTRANS_CLIENT_KEY=SB-Mid-client-xxxxxxxxxxxx
MIDTRANS_IS_PRODUCTION=false

# Biteship Logistik
BITESHIP_API_KEY=biteship_test.xxxxxxxxxxxx

# Session
SESSION_SECRET=ganti_dengan_session_secret_panjang

# CORS (URL frontend)
CLIENT_URL=http://localhost:5173
